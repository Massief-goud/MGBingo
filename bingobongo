<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jungle Bingo Beheer</title>
<style>
*{box-sizing:border-box}
/* De achtergrond is nu gekoppeld aan jouw directe Postimg link */
body{
 font-family:Arial,sans-serif;
 background: url('https://i.postimg.cc/QNKW18c2/pexels-harsh-srivastava-1765262842-30201600.jpg') center/cover no-repeat fixed;
 color:white;
 margin:0;
 padding:20px;
}
.tabs{display:flex;gap:10px;margin-bottom:15px}
button{padding:10px 14px;border:none;border-radius:8px;cursor:pointer;background:rgba(68, 68, 68, 0.9);color:white;font-weight:bold}
button:hover{background:rgba(85, 85, 85, 0.9)}
.btn-save{background:rgba(0, 188, 212, 0.9);color:black}
.btn-screenshot{background:rgba(76, 175, 80, 0.9);color:white}
.btn-preview{background:rgba(255, 152, 0, 0.9);color:black}
input{padding:10px;border-radius:8px;border:none;background:rgba(34, 34, 34, 0.9);color:white;border:1px solid #444}
.panel{display:none}
.panel.active{display:block}
.controls{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:15px}

/* Grote Bingo Kaart styling */
.bingo-board{
 position:relative;width:min(90vw,600px);aspect-ratio:1/1;margin:0 auto;
 background:url('https://i.postimg.cc/cHXMXPfN/bingo-template.png') center/contain no-repeat;
}
.team-overlay {
 position:absolute;top:2.5%;left:0;width:100%;
 text-align:center;font-size:calc(14px + 1.5vw);font-weight:Bold;
 color:#46510e;text-shadow: 1px 1px 10px rgba(255,255,255,255);
 pointer-events:none;text-transform:uppercase;letter-spacing:1px;
}
.grid{
 position:absolute;top:10.5%;left:10.5%;width:79%;height:79%;
 display:grid;grid-template-columns:repeat(4,1fr);grid-template-rows:repeat(4,1fr);
}
.cell{position:relative;cursor:pointer}
.cell.checked::before,.cell.checked::after{
 content:"";position:absolute;top:50%;left:50%;
 width:85%;height:14px;background:rgba(0,255,80,.35);border-radius:999px;
}
.cell.checked::before{transform:translate(-50%,-50%) rotate(45deg)}
.cell.checked::after{transform:translate(-50%,-50%) rotate(-45deg)}
.card-item{background:rgba(34, 34, 34, 0.9);padding:10px;margin:8px 0;border-radius:8px;display:flex;justify-content:space-between;align-items:center}

/* Openbare overzicht-kaarten matrix */
.public-grid-container {
 display:grid;grid-template-columns:repeat(auto-fill, minmax(220px, 1fr));gap:20px;margin-top:15px;
}
.public-card {
 background:rgba(34, 34, 34, 0.9);border:1px solid #333;border-radius:12px;padding:15px;
 display:flex;flex-direction:column;align-items:center;gap:10px;
}
.public-card h3 {
 margin:0;font-size:16px;text-transform:uppercase;color:#939168;text-align:center;
 width:100%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
}
.mini-board {
 position:relative;width:100%;aspect-ratio:1/1;
 background:url('https://i.postimg.cc/cHXMXPfN/bingo-template.png') center/contain no-repeat;
}
.mini-grid {
 position:absolute;top:10.5%;left:10.5%;width:79%;height:79%;
 display:grid;grid-template-columns:repeat(4,1fr);grid-template-rows:repeat(4,1fr);
}
.mini-cell { position:relative; }
.mini-cell.checked::before,.mini-cell.checked::after{
 content:"";position:absolute;top:50%;left:50%;
 width:85%;height:4px;background:rgba(0,255,80,.6);border-radius:999px;
}
.mini-cell.checked::before{transform:translate(-50%,-50%) rotate(45deg)}
.mini-cell.checked::after{transform:translate(-50%,-50%) rotate(-45deg)}
.public-card button { width:100%; margin-top:5px; }

/* Preview Pop-up (Modal) Styling */
.preview-modal {
 display:none;position:fixed;top:0;left:0;width:100%;height:100%;
 background:rgba(0,0,0,0.9);z-index:9999;justify-content:center;align-items:center;
 padding:20px;
}
.preview-modal.active { display:flex; }
.modal-content {
 position:relative;width:100%;max-width:650px;
 display:flex;flex-direction:column;gap:15px;
}
.modal-close {
 position:absolute;top:-45px;right:0;font-size:32px;color:white;
 background:none;border:none;cursor:pointer;font-weight:bold;
}
.modal-close:hover { color:#ff9800; }
</style>
</head>
<body>

<div class="tabs">
<button onclick="showTab('public')">Overzicht Kaarten</button>
<button onclick="showTab('editor')">Bingo Kaart</button>
<button onclick="showTab('saved')">Opgeslagen Kaarten (Staff)</button>
</div>

<!-- Openbaar overzicht tabblad -->
<div id="public" class="panel active">
<h2>Actueel Overzicht van alle deelnemende kaarten</h2>
<p>Klik op "Bekijken " om een kaart te bekijken, Duh *Yoink*.</p>
<div id="publicCardsContainer" class="public-grid-container"></div>
</div>

<!-- Editor panel -->
<div id="editor" class="panel">
<div class="controls">
<input id="teamName" placeholder="Teamnaam" oninput="updateTeamOverlay()">
<button class="btn-save" onclick="saveCard()">Opslaan</button>
<button class="btn-screenshot" onclick="takeScreenshot()">Screenshot 📷</button>
<button onclick="newCard()">Nieuwe kaart</button>
</div>

<div class="bingo-board">
<div id="teamOverlay" class="team-overlay"></div>
<div class="grid" id="grid"></div>
</div>
</div>

<!-- Beheer panel -->
<div id="saved" class="panel">
<h2>Opgeslagen kaarten (Beheer)</h2>
<div id="savedCards"></div>
</div>

<!-- Het Preview Pop-up Scherm -->
<div id="previewModal" class="preview-modal" onclick="closePreview(event)">
 <div class="modal-content" onclick="event.stopPropagation()">
   <button class="modal-close" onclick="closePreview(null)">&times;</button>
   <div class="bingo-board">
     <div id="previewTeamOverlay" class="team-overlay"></div>
     <div id="previewGrid" class="grid"></div>
   </div>
 </div>
</div>

<script>
const PASSWORD="1337";
let editUnlocked=false;
const BG_IMAGE_URL = 'https://i.postimg.cc/cHXMXPfN/bingo-template.png';

document.addEventListener("DOMContentLoaded", () => {
 loadPublicCards();
 buildEditorGrid();
 buildPreviewGrid();
});

function unlockEdit(){
 if(editUnlocked) return true;
 const p=prompt("Voer beheerderscode in:");
 if(p===PASSWORD){editUnlocked=true;return true;}
 alert("Onjuiste code");
 return false;
}

function showTab(id){
 document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
 document.getElementById(id).classList.add('active');
 if(id==='saved') loadSavedCards();
 if(id==='public') loadPublicCards();
}

function updateTeamOverlay() {
 const name = document.getElementById('teamName').value;
 document.getElementById('teamOverlay').innerText = name;
}

function buildEditorGrid() {
 const grid = document.getElementById('grid');
 grid.innerHTML = '';
 for(let i=0;i<16;i++){
  let c=document.createElement('div');
  c.className='cell';
  c.onclick=()=>{
    if(!unlockEdit()) return;
    c.classList.toggle('checked');
  };
  grid.appendChild(c);
 }
}

function buildPreviewGrid() {
 const pGrid = document.getElementById('previewGrid');
 pGrid.innerHTML = '';
 for(let i=0;i<16;i++){
  let c=document.createElement('div');
  c.className='cell'; 
  pGrid.appendChild(c);
 }
}

function saveCard(){
 const team=document.getElementById('teamName').value.trim();
 if(!team) return alert('Voer een teamnaam in');
 const checked=[];
 document.querySelectorAll('#grid .cell').forEach((c,i)=>{
   if(c.classList.contains('checked')) checked.push(i);
 });
 localStorage.setItem('bingo_'+team,JSON.stringify({team,checked}));
 alert('Opgeslagen');
 loadSavedCards();
 loadPublicCards();
}

function newCard(){
 document.getElementById('teamName').value='';
 updateTeamOverlay();
 document.querySelectorAll('#grid .cell').forEach(c=>c.classList.remove('checked'));
}

function loadSavedCards(){
 const container=document.getElementById('savedCards');
 container.innerHTML='';
 Object.keys(localStorage)
 .filter(k=>k.startsWith('bingo_'))
 .forEach(key=>{
   const data=JSON.parse(localStorage.getItem(key));
   const row=document.createElement('div');
   row.className='card-item';
   row.innerHTML=`<span>${data.team}</span>
   <span>
   <button onclick="editCard('${data.team}')">Bewerken</button>
   <button onclick="deleteCard('${data.team}')">Verwijderen</button>
   </span>`;
   container.appendChild(row);
 });
}

function loadPublicCards(){
 const container=document.getElementById('publicCardsContainer');
 container.innerHTML='';
 
 const keys = Object.keys(localStorage).filter(k=>k.startsWith('bingo_'));
 
 if(keys.length === 0) {
   container.innerHTML = '<p style="grid-column: 1/-1; color: #aaa;">Er zijn nog geen bingokaarten opgeslagen.</p>';
   return;
 }
 
 keys.forEach(key=>{
   const data=JSON.parse(localStorage.getItem(key));
   const cardDiv = document.createElement('div');
   cardDiv.className = 'public-card';
   
   cardDiv.innerHTML = `
     <h3>${data.team}</h3>
     <div class="mini-board">
       <div class="mini-grid"></div>
     </div>
     <button class="btn-preview" onclick="openPreview('${data.team.replace(/'/g, "\\'")}')">Bekijken </button>
   `;
   
   const miniGrid = cardDiv.querySelector('.mini-grid');
   for(let i=0; i<16; i++) {
     const miniCell = document.createElement('div');
     miniCell.className = 'mini-cell';
     if(data.checked.includes(i)) miniCell.classList.add('checked');
     miniGrid.appendChild(miniCell);
   }
   container.appendChild(cardDiv);
 });
}

function openPreview(teamName) {
 const data = JSON.parse(localStorage.getItem('bingo_' + teamName));
 if(!data) return;
 
 document.getElementById('previewTeamOverlay').innerText = data.team;
 
 const previewCells = document.querySelectorAll('#previewGrid .cell');
 previewCells.forEach((cell, i) => {
   if(data.checked.includes(i)) {
     cell.classList.add('checked');
   } else {
     cell.classList.remove('checked');
   }
 });
 
 document.getElementById('previewModal').classList.add('active');
}

function closePreview(event) {
 if(!event || event.target.id === 'previewModal') {
   document.getElementById('previewModal').classList.remove('active');
 }
}

function editCard(team){
 if(!unlockEdit()) return;
 const data=JSON.parse(localStorage.getItem('bingo_'+team));
 showTab('editor');
 newCard();
 document.getElementById('teamName').value=data.team;
 updateTeamOverlay();
 data.checked.forEach(i=>{
   document.querySelectorAll('#grid .cell')[i].classList.add('checked');
 });
}

function deleteCard(team){
 if(!unlockEdit()) return;
 if(confirm('Kaart verwijderen?')){
   localStorage.removeItem('bingo_'+team);
   loadSavedCards();
   loadPublicCards();
 }
}

function takeScreenshot() {
 const teamName = document.getElementById('teamName').value.trim() || "Jungle Bingo";
 const checked = [];
 document.querySelectorAll('#grid .cell').forEach((c,i)=>{
   if(c.classList.contains('checked')) checked.push(i);
 });
 
 const img = new Image();
 img.crossOrigin = "anonymous";
 img.src = BG_IMAGE_URL;
 img.onload = function() {
   const canvas = document.createElement('canvas');
   const ctx = canvas.getContext('2d');
   canvas.width = img.width;
   canvas.height = img.height;
   ctx.drawImage(img, 0, 0);
   
   ctx.font = "bold 46px Copperplate";
   ctx.fillStyle = "#ab8038";
   ctx.shadowColor = "rgba(0, 0, 0, 0.8)";
   ctx.shadowBlur = 6; ctx.shadowOffsetX = 6; ctx.shadowOffsetY = 6;
   ctx.textAlign = "center";
   ctx.fillText(teamName.toUpperCase(), canvas.width / 2, canvas.height * 0.08);
   
   ctx.shadowBlur = 0; ctx.shadowOffsetX = 0; ctx.shadowOffsetY = 0;
   const gridTop = canvas.height * 0.105;
   const gridLeft = canvas.width * 0.105;
   const gridSize = canvas.width * 0.79;
   const cellSize = gridSize / 4;
   
   checked.forEach(index => {
     const row = Math.floor(index / 4); const col = index % 4;
     const centerX = gridLeft + (col * cellSize) + (cellSize / 2);
     const centerY = gridTop + (row * cellSize) + (cellSize / 2);
     const lineLength = cellSize * 0.42;
     ctx.strokeStyle = "rgba(0, 255, 80, 0.45)"; ctx.lineWidth = 16; ctx.lineCap = "round";
     ctx.beginPath(); ctx.moveTo(centerX - lineLength, centerY - lineLength); ctx.lineTo(centerX + lineLength, centerY + lineLength); ctx.stroke();
     ctx.beginPath(); ctx.moveTo(centerX - lineLength, centerY + lineLength); ctx.lineTo(centerX + lineLength, centerY - lineLength); ctx.stroke();
   });
   
   const link = document.createElement('a');
   link.download = `Bingo_${teamName.replace(/[^a-z0-9]/gi, '_')}.png`;
   link.href = canvas.toDataURL('image/png');
   link.click();
 };
}
</script>
</body>
</html>
